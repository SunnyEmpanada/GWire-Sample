# GWire local environment reference.
#
# Copy this file to .env for local use, then fill in values.
# Do not commit .env; it can contain server-only Supabase secrets.

# Risk persistence mode:
# - memory: original local-only behavior; no Supabase required.
# - supabase: persist risk ranks in Supabase and hydrate the local cache on startup.
RISK_PERSISTENCE=memory

# Required when RISK_PERSISTENCE=supabase.
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only credential. Never expose this in browser code or any VITE_* variable.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-server-only-key

# Optional alternative if you use Supabase's newer server-side secret key format.
# If set, this is used before SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEY=replace-with-your-server-only-secret-key

